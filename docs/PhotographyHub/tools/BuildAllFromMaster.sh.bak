#!/usr/bin/env bash
set -euo pipefail

# ====== CONFIG ======
VOLUME="Extreme SSD"
HUB_ROOT="/Volumes/${VOLUME}/Backup_Files_To_NAS/PhotographyHub"
PAGES="$HUB_ROOT/pages"
TOOLS="$HUB_ROOT/tools"
MASTER="$PAGES/MASTER-steps.txt"
INDEX="$HUB_ROOT/index.html"
TITLE="Photography Workflow Hub"
# ====================

ts(){ date "+%Y-%m-%d %H:%M:%S"; }

echo "[$(ts)] Build starting…"
[[ -d "/Volumes/${VOLUME}" ]] || { echo "[$(ts)] ERROR: SanDisk not mounted at /Volumes/${VOLUME}"; exit 1; }
[[ -f "$MASTER" ]] || { echo "[$(ts)] ERROR: MASTER file not found: $MASTER"; exit 1; }
mkdir -p "$PAGES" "$TOOLS"

# 1) Clean previously generated .html pages (keep template.html if present)
echo "[$(ts)] Cleaning old generated pages…"
find "$PAGES" -type f -name '*.html' ! -name 'template.html' -delete 2>/dev/null || true

# 2) Parse MASTER and generate per-page HTMLs + collect card metadata
META_TMP="$(mktemp)"
trap 'rm -f "$META_TMP"' EXIT

/usr/bin/awk -v PAGES_DIR="$PAGES" '
function trim(s){ gsub(/^[ \t\r\n]+|[ \t\r\n]+$/,"",s); return s }
function slugify(s,  t){
  t=tolower(s)
  gsub(/[^a-z0-9]+/, "-", t)
  gsub(/^-+|-+$/, "", t)
  return (t=="" ? "untitled" : t)
}
function html_escape(s){
  gsub(/&/,"&amp;",s); gsub(/</,"&lt;",s); gsub(/>/,"&gt;",s)
  return s
}
function summarize(txt,  s){
  s=txt
  gsub(/\r/,"",s)
  gsub(/\n+/," ",s)
  sub(/^[ \t]+/,"",s)
  if(length(s)>180) s=substr(s,1,177)"…"
  return s
}
function emit_para(){
  if (para!=""){ body_html=body_html "<p>" html_escape(para) "</p>\n"; para="" }
}
function close_list(){
  if (in_list){ body_html=body_html "</ul>\n"; in_list=0 }
}
function flush_block(){
  if (title=="") return
  # Defaults
  if (slug=="") slug = slugify(title)
  if (order=="") order="999"
  if (back=="") back="../index.html"
  if (summary=="") summary = summarize(body)

  # Transform body to HTML: headings (#, ##), bullet lists (- ), paragraphs
  split(body, lines, "\n")
  body_html = ""
  para = ""
  in_list = 0

  for(i=1;i<=length(lines);i++){
    line = lines[i]

    # Blank line: close para and list
    if (line ~ /^[ \t]*$/){
      emit_para()
      close_list()
      continue
    }

    # H2: "# "
    if (match(line, /^[ \t]*#[ \t]+(.*)$/, m)){
      emit_para(); close_list()
      body_html = body_html "<h2>" html_escape(m[1]) "</h2>\n"
      continue
    }
    # H3: "## "
    if (match(line, /^[ \t]*##[ \t]+(.*)$/, m)){
      emit_para(); close_list()
      body_html = body_html "<h3>" html_escape(m[1]) "</h3>\n"
      continue
    }

    # Bullet list: "- "
    if (match(line, /^[ \t]*-[ \t]+(.*)$/, m)){
      emit_para()
      if (!in_list){ body_html = body_html "<ul>\n"; in_list=1 }
      body_html = body_html "  <li>" html_escape(m[1]) "</li>\n"
      continue
    }

    # Otherwise, accumulate into a paragraph (space-separated)
    if (para!="") para = para " " line
    else para = line
  }
  emit_para(); close_list()

  # Write page file
  out = PAGES_DIR "/" slug ".html"
  print "<!doctype html>"                            > out
  print "<html lang=\"en\">"                        >> out
  print "<head><meta charset=\"utf-8\">"            >> out
  print "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">" >> out
  print "<title>" html_escape(title) "</title>"     >> out
  print "<style>body{margin:24px;font:16px/1.6 -apple-system,BlinkMacSystemFont,\"Segoe UI\",Arial,sans-serif;background:#eef1f4;color:#101828}a{color:#0e49c2;text-decoration:none}a:hover{text-decoration:underline}.wrap{max-width:900px;margin:0 auto}.card{background:#fff;border-radius:14px;padding:20px;box-shadow:0 6px 18px rgba(16,24,40,.08)}.back{margin:0 0 16px;display:inline-block}ul{margin:0 0 1rem 1.25rem}h2{margin:1rem 0 .5rem}h3{margin:.75rem 0 .4rem}</style>" >> out
  print "</head><body><div class=\"wrap\">"         >> out
  print "<a class=\"back\" href=\"" back "\">← Back</a>" >> out
  print "<div class=\"card\">"                      >> out
  print "<h1>" html_escape(title) "</h1>"           >> out
  print body_html                                   >> out
  print "</div></div></body></html>"                >> out
  close(out)

  # Emit card metadata line: order|slug|title|summary
  gsub(/\|/," - ",summary)
  print order "|" slug "|" title "|" summary
}
BEGIN{
  title=slug=summary=order=back=body=""
}
{
  if ($0 ~ /^@@[ \t]+title[ \t]*:/){
    flush_block()
    title = $0
    sub(/^@@[ \t]+title[ \t]*:/,"",title); title=trim(title)
    slug=summary=order=back=""; body=""
    next
  }
  if ($0 ~ /^@@[ \t]+slug[ \t]*:/){ slug=$0; sub(/^@@[ \t]+slug[ \t]*:/,"",slug); slug=trim(slug); next }
  if ($0 ~ /^@@[ \t]+summary[ \t]*:/){ summary=$0; sub(/^@@[ \t]+summary[ \t]*:/,"",summary); summary=trim(summary); next }
  if ($0 ~ /^@@[ \t]+order[ \t]*:/){ order=$0; sub(/^@@[ \t]+order[ \t]*:/,"",order); order=trim(order); next }
  if ($0 ~ /^@@[ \t]+back[ \t]*:/){ back=$0; sub(/^@@[ \t]+back[ \t]*:/,"",back); back=trim(back); next }

  body = body $0 "\n"
}
END{
  flush_block()
}
' "$MASTER" > "$META_TMP"

# 3) Build index.html from metadata (sorted by order)
echo "[$(ts)] Writing index…"
BUILT_AT="$(date '+%Y-%m-%d %H:%M')"

{
  cat <<HTML_HEAD
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>$TITLE</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root { --bg:#eef1f4; --fg:#101828; --card:#fff; --accent:#0e49c2; --muted:#475467; }
    body{margin:24px;font:16px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;background:var(--bg);color:var(--fg)}
    h1{margin:0 0 6px}
    .built{margin:0 0 16px;color:#475467}
    .grid{max-width:1100px;margin:0 auto;display:grid;gap:16px;grid-template-columns:repeat(auto-fill,minmax(280px,1fr))}
    .card{background:var(--card);border-radius:14px;padding:16px 16px 18px;box-shadow:0 6px 18px rgba(16,24,40,.08)}
    .card h2{margin:0 0 6px;font-size:18px}
    .card p{margin:0 0 10px;color:var(--muted)}
    a{color:#0e49c2;text-decoration:none} a:hover{text-decoration:underline}
  </style>
  <!-- Option B: open card links in a separate window -->
  <script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.grid .card a[target="_blank"]').forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        // One named window reused; pop-up blockers allow due to user click
        window.open(a.href, 'HubStep', 'noopener,width=1100,height=800');
      });
    });
  });
  </script>
</head>
<body>
  <h1>$TITLE</h1>
  <p class="built">Last built: $BUILT_AT</p>
  <div class="grid">
HTML_HEAD

  # Emit cards (links carry target to be intercepted by the script above)
  sort -t"|" -k1,1n "$META_TMP" | while IFS="|" read -r ord slug title summary; do
    esc_title=${title//&/&amp;}; esc_title=${esc_title//</&lt;}; esc_title=${esc_title//>/&gt;}
    esc_summary=${summary//&/&amp;}; esc_summary=${esc_summary//</&lt;}; esc_summary=${esc_summary//>/&gt;}
    printf '    <div class="card"><h2><a target="_blank" rel="noopener" href="pages/%s.html">%s</a></h2><p>%s</p><a target="_blank" rel="noopener" href="pages/%s.html">Open ↗</a></div>\n' \
      "$slug" "$esc_title" "$esc_summary" "$slug"
  done

  cat <<HTML_TAIL
  </div>
</body>
</html>
HTML_TAIL
} > "$INDEX"

# 4) Inject Tools panel right AFTER the "Last built" line if the fragment exists
TOOLS_FRAG="$TOOLS/hub_tools.html"
if [[ -f "$TOOLS_FRAG" && -f "$INDEX" ]]; then
  echo "[$(ts)] Injecting tools panel…"
  tmp="$HUB_ROOT/.index.tmp"
  awk -v frag="$TOOLS_FRAG" '
    {
      print $0
      if (inserted==0 && $0 ~ /<p class="built">/) {
        system("cat \"" frag "\"")
        inserted=1
      }
    }
  ' "$INDEX" > "$tmp" && mv "$tmp" "$INDEX"
fi

echo "[$(ts)] Build complete."
# Prefer Safari for file:// .command links; fall back to default browser
open -a "Safari" "$INDEX" 2>/dev/null || open "$INDEX" 2>/dev/null || true